# ── Spotify API ──────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Target Spotify playlist ID (from the playlist URL)
SPOTIFY_PLAYLIST_ID=your_playlist_id_here

# ── YT Music ─────────────────────────────────────────────────────
# Source playlist ID (from URL: https://music.youtube.com/playlist?list=PLAYLIST_ID)
YTMUSIC_PLAYLIST_ID=your_playlist_id_here

# Auth file created by 'setup-ytmusic' command
YTMUSIC_AUTH_FILE=browser.json

# ── Last.fm API (optional, for enrichment) ──────────────────────
# Free API key from https://www.last.fm/api/account/create
# Adds play counts, listener counts, and genre tags to enriched CSV
# LASTFM_API_KEY=your_api_key_here

# ── Optional ─────────────────────────────────────────────────────
# Path to a CSV export of your playlist (for --from-csv mode)
# SOURCE_CSV=playlist_export.csv
